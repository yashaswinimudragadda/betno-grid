<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/png" sizes="32x32" href="./assets/images/favicon-32x32.png">
  <title>Frontend Mentor | Bento grid</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;1,9..40,700&display=swap" rel="stylesheet">
  
  <link rel="stylesheet" href="style.css">
</head>
<body class="bg-light">

  <main class="container my-5">
    <div class="row g-4">
      
      <div class="col-lg-3 d-flex flex-column gap-4">
        <div class="card p-4 bg-yellow-100 border-0 h-100">
           <h3>Create and schedule content <span class="text-purple-500">quicker.</span></h3>
           <img src="./assets/images/illustration-create-post.webp" alt="Create post" class="img-fluid mt-auto">
        </div>
        <div class="card p-4 bg-yellow-500 border-0 h-100">
           <h3>Write your content using AI.</h3>
           <img src="./assets/images/illustration-ai-content.webp" alt="AI content" class="img-fluid mt-auto">
        </div>
      </div>

      <div class="col-lg-6">
        <div class="row g-4">
          <div class="col-12">
            <div class="card p-5 bg-purple-500 text-white text-center border-0">
               <h1 class="display-5 fw-bold">Social Media <span class="text-yellow-500">10x</span> Faster with AI</h1>
               <div class="mt-3">
                 <img src="./assets/images/illustration-five-stars.webp" alt="stars" style="width: 150px;">
                 <p class="mt-2">Over 4,000 5-star reviews</p>
               </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="card p-4 bg-white border-0 h-100">
              <img src="./assets/images/illustration-multiple-platforms.webp" alt="Platforms" class="img-fluid mb-3">
              <h3>Manage multiple accounts and platforms.</h3>
            </div>
          </div>
          <div class="col-md-6">
            <div class="card p-4 bg-yellow-500 border-0 h-100">
              <h3>Maintain a consistent posting schedule.</h3>
              <img src="./assets/images/illustration-consistent-schedule.webp" alt="Schedule" class="img-fluid mt-3">
            </div>
          </div>
        </div>
      </div>

      <div class="col-lg-3">
        <div class="card p-4 bg-purple-100 border-0 h-100">
          <h3>Schedule to social media.</h3>
          <img src="./assets/images/illustration-schedule-posts.webp" alt="Schedule posts" class="img-fluid my-4">
          <p>Optimize post timings to publish content at the perfect time for your audience.</p>
        </div>
      </div>

      <div class="col-lg-3">
          </div>
      <div class="col-lg-3">
        <div class="card p-4 bg-white border-0  boxlast2">
          <h2 class="display-6 fw-bold">>56%</h2>
          <p>faster audience growth</p>
          <img src="./assets/images/illustration-audience-growth.webp" alt="Growth" class="img-fluid">
        </div>
        <div class="col-lg-6  boxlast1">
          <div class="card p-4 bg-purple-500 text-white border-0 d-flex flex-row align-items-center">
            <img src="./assets/images/illustration-grow-followers.webp" alt="Followers" class="img-fluid w-50">
            <h3 class="ms-3">Grow followers with non-stop content.</h3>
          </div>
        </div>
       </div>
   

    </div>
  </main>

</body>
</html>